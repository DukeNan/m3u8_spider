# 复制此文件为 .env 并填写实际值。配置说明见项目根目录 config.py。
# cp env.example .env

# MySQL 数据库配置（自动下载守护进程必需）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=video_db

# MySQL 客户端超时（秒，默认值已内置于 config.py，此处为可选覆盖）
MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=120
MYSQL_WRITE_TIMEOUT=120

# 下载检查间隔（秒），默认 60
DOWNLOAD_CHECK_INTERVAL=60

# M3U8 URL 刷新守护进程（m3u8-refresh）可选
# M3U8_REFRESH_INTERVAL=300
# M3U8_REFRESH_MIN_MINUTES=10

# 以下为可选的默认值覆盖，不设置时使用 config.py 中的默认值
# DEFAULT_CONCURRENT=32
# DEFAULT_DELAY=0
# DOWNLOAD_COOLDOWN_SECONDS=30
# LOG_LEVEL=INFO
